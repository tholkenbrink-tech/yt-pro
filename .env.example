# --- NAS host user (avoid running containers as root) ---
PUID=1000
PGID=1000

# --- Single local admin account (seeded on first boot only) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-boot

# --- Session security ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-value

# --- CORS: must list the exact Cloudflare Pages origin(s) that call this API ---
CORS_ORIGINS=https://yt-pro.pages.dev

# --- Job / storage limits ---
DEFAULT_RETENTION_HOURS=24
MAX_PLAYLIST_ITEMS=50
MAX_CONCURRENT_JOBS=2
MIN_FREE_DISK_BYTES=2147483648

# --- Cloudflare Tunnel token (from the Zero Trust dashboard, one per tunnel) ---
CLOUDFLARE_TUNNEL_TOKEN=
