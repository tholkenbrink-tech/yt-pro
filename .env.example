# --- NAS host user (avoid running containers as root) ---
PUID=1000
PGID=1000

# --- Single local admin account (seeded on first boot only) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=example

# --- Session security ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- CORS: must list the exact frontend origin(s) that call this API ---
CORS_ORIGINS=https://app.yt-pro.de

# --- Cookie domain for the CSRF cookie, so frontend JS can read it cross-subdomain.
# Only set this if the API and frontend live on different subdomains of the same
# registrable domain (e.g. api.yt-pro.de / app.yt-pro.de) - leave unset for local dev.
COOKIE_DOMAIN=.yt-pro.de

# --- Job / storage limits ---
DEFAULT_RETENTION_HOURS=24
MAX_PLAYLIST_ITEMS=50
MAX_CONCURRENT_JOBS=2
MIN_FREE_DISK_BYTES=2147483648

# --- Cloudflare Tunnel token (from the Zero Trust dashboard, one per tunnel) ---
CLOUDFLARE_TUNNEL_TOKEN=